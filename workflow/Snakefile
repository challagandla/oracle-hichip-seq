# ORACLE HiChIP pipeline — main Snakefile
# Run from repository root:
#   snakemake -s workflow/Snakefile -n --configfile config/config.yaml
#   snakemake -s workflow/Snakefile --cores 32 --configfile config/config.yaml --use-conda
#
# Stages:
#   00_fetch_sra       Download FASTQs from SRA (technical replicates merged)
#   01_qc_raw          FastQC + fastp adapter/quality trim
#   02_align_pairs     bwa-mem2 -SP5M + pairtools parse/sort/dedup → .pairs.gz
#   03_cool_matrix     cooler load + zoomify + balance (ICE)
#   04_peaks           Extract 1D reads, MACS2 narrow/broad peaks per mark
#   05_loops_fithichip FitHiChIP Peak-to-ALL loop calling
#   06_loop_qc         cis/trans, P(s), insulation, APA, HiCRep replicate QC
#   06b_stripes        architectural stripe calling (Stripenn)
#   07_differential    mark-stratified differential loops
#   08_viz             pyGenomeTracks, APA plots, virtual 4C
#   09_export_oracle   Multi-resolution COS graph + node features (PyG / .h5)
#   10_multiqc         Aggregate MultiQC across all stages

import os
import re
import yaml
import pandas as pd
from pathlib import Path

# ---------- Config & sample sheet ----------
configfile: "config/config.yaml"

with open(config["genome_yaml"]) as fh:
    GENOME_CFG = yaml.safe_load(fh)
ASSEMBLY = config["assembly"]
GENOME = GENOME_CFG[ASSEMBLY]

SAMPLES = pd.read_csv(config["samples_tsv"], sep="\t", dtype=str, comment="#").set_index("sample_id", drop=False)
SAMPLE_IDS = SAMPLES["sample_id"].tolist()
MARKS = sorted(SAMPLES["mark"].dropna().unique())

RESULTS = Path(config["results_dir"])
FITHICHIP_Q_LABEL = f"Q{config['fithichip']['fdr_threshold']}"
ORACLE_BIN_SIZES_BP = [int(k) * 1000 for k in config["cooler"]["oracle_bin_sizes_kb"]]

# FitHiChIP names its output directories after the interaction type and bias model,
# using these strings rather than the numeric codes it takes in the config. Deriving
# them from the same codes keeps the path we read from in step with the config we
# write -- FitHiChIP also builds an ALL2ALL directory while computing the background,
# so reading the wrong one silently returns a different call set.
_FITHICHIP_INT_DIRS = {1: "Peak2Peak", 2: "Peak2NonPeak", 3: "Peak2ALL", 4: "ALL2ALL"}
_FITHICHIP_BIAS_DIRS = {1: "Coverage_Bias", 2: "ICE_Bias"}
FITHICHIP_INT_DIR = _FITHICHIP_INT_DIRS[int(config["fithichip"]["int_type_code"])]
FITHICHIP_BIAS_DIR = _FITHICHIP_BIAS_DIRS[int(config["fithichip"]["bias_type_code"])]
FITHICHIP_MERGE = bool(config["fithichip"].get("merge_nearby", True))

_fc = config["fithichip"]
_FITHICHIP_BASE = (
    f"FitHiChIP_{FITHICHIP_INT_DIR}_b{_fc['bin_size']}"
    f"_L{_fc['lower_distance']}_U{_fc['upper_distance']}"
)
# The P2PBckgr_<n> level only exists when the peak-to-peak background is in use.
_FITHICHIP_PARTS = [_FITHICHIP_BASE]
if _fc.get("use_p2p_background", 1):
    _FITHICHIP_PARTS.append(f"P2PBckgr_{_fc['use_p2p_background']}")
_FITHICHIP_PARTS += [FITHICHIP_BIAS_DIR, "FitHiC_BiasCorr"]

# FitHiChIP emits BOTH a raw call set and, under Merge_Nearby_Interactions/, the same
# set with adjacent significant bin pairs collapsed into one contact. The raw set
# reports a single physical loop once per adjacent bin pair it spans -- 30,903 raw
# against 17,875 merged on Th17_H3K27ac_rep1, i.e. 42% redundant. Setting MergeInt=1
# only makes FitHiChIP WRITE the merged file; it still has to be the one read.
if FITHICHIP_MERGE:
    _FITHICHIP_PARTS.append("Merge_Nearby_Interactions")
    FITHICHIP_RESULT_FILE = (
        "{sample}.interactions_FitHiC_" + FITHICHIP_Q_LABEL + "_MergeNearContacts.bed"
    )
else:
    FITHICHIP_RESULT_FILE = "{sample}.interactions_FitHiC_" + FITHICHIP_Q_LABEL + ".bed"
FITHICHIP_RESULT_DIR = "/".join(_FITHICHIP_PARTS)

# convenience accessors used by rule files
def fastq_r1(wc): return SAMPLES.loc[wc.sample, "fastq_r1"]
def fastq_r2(wc): return SAMPLES.loc[wc.sample, "fastq_r2"]
def sample_mark(wc): return SAMPLES.loc[wc.sample, "mark"]
def fithichip_loop_path(sample):
    return RESULTS / f"loops/{sample}/{sample}.interactions_FitHiC_{FITHICHIP_Q_LABEL}.bed"

# ---------- Wildcard constraints ----------
# `sample` and `region` both legitimately contain underscores (e.g. sample
# "HCT_OV_001_R1", region "MYC_locus"), and several outputs join them as
# "{sample}_{region}". Without exact-value constraints Snakemake cannot
# unambiguously split that filename. Pin both to the known values so the
# split is deterministic.
VIZ_REGION_NAMES = [r["name"] for r in config["viz"]["regions"]]
DIFF_COMPARISON_NAMES = [c["name"] for c in config.get("differential", {}).get("comparisons", [])]

wildcard_constraints:
    sample = "|".join(re.escape(s) for s in SAMPLE_IDS),
    res    = r"\d+",
    mark   = r"[A-Za-z0-9]+",
    region = "|".join(re.escape(r) for r in VIZ_REGION_NAMES) or r"[A-Za-z0-9_\-]+",
    comparison = ("|".join(re.escape(c) for c in DIFF_COMPARISON_NAMES)
                  or r"[A-Za-z0-9_\-]+")

# ---------- Include all rule files ----------
include: "rules/00_fetch_sra.smk"
include: "rules/01_qc_raw.smk"
include: "rules/02_align_pairs.smk"
include: "rules/03_cool_matrix.smk"
include: "rules/04_peaks.smk"
include: "rules/05_loops_fithichip.smk"
include: "rules/06_loop_qc.smk"
include: "rules/06b_stripes.smk"
include: "rules/07_differential.smk"
include: "rules/08_viz.smk"
include: "rules/09_export_oracle.smk"
include: "rules/10_multiqc.smk"
include: "rules/11_figures.smk"

# ---------- Top-level targets ----------
rule all:
    input:
        # Per-sample core artefacts
        expand(RESULTS / "cool/{sample}.mcool", sample=SAMPLE_IDS),
        expand(RESULTS / "peaks/{sample}_peaks.bed", sample=SAMPLE_IDS),
        expand(RESULTS / f"loops/{{sample}}/{{sample}}.interactions_FitHiC_{FITHICHIP_Q_LABEL}.bed", sample=SAMPLE_IDS),
        expand(RESULTS / "qc/loop_qc/{sample}.json", sample=SAMPLE_IDS),
        # ORACLE-ready exports
        expand(RESULTS / "oracle_cos/{sample}.pt", sample=SAMPLE_IDS),
        # Visualisation
        expand(RESULTS / "viz/{sample}_{region}.png",
               sample=SAMPLE_IDS,
               region=[r["name"] for r in config["viz"]["regions"]]),
        # Virtual 4C from each locus viewpoint. The rule existed but was reachable
        # from no target, so it never ran -- and it is the view that shows an
        # enhancer looking at its target gene, which is the point of the cohort.
        expand(RESULTS / "viz/virtual_4c/{sample}_{region}.v4c.png",
               sample=SAMPLE_IDS,
               region=[r["name"] for r in config["viz"]["regions"]]),
        # Architectural stripes
        *( [RESULTS / "stripes/stripe_summary.tsv"] if config.get("stripes", {}).get("enabled") else [] ),
        # Differential loops per comparison
        expand(RESULTS / "diff/{comparison}/differential_loops.tsv",
               comparison=[c["name"] for c in config.get("differential", {}).get("comparisons", [])]),
        # MultiQC aggregate report
        RESULTS / "multiqc/multiqc_report.html",
        # Cohort publication figures
        RESULTS / "figures/library_summary.tsv",

# ---------- Convenience phony targets ----------
rule qc_raw:
    input:
        expand(RESULTS / "qc/fastqc_raw/{sample}_R1_fastqc.html", sample=SAMPLE_IDS)

rule align_pairs:
    input:
        expand(RESULTS / "pairs/{sample}.dedup.pairs.gz", sample=SAMPLE_IDS)

rule cool_matrix:
    input:
        expand(RESULTS / "cool/{sample}.mcool", sample=SAMPLE_IDS)

rule peaks:
    input:
        expand(RESULTS / "peaks/{sample}_peaks.bed", sample=SAMPLE_IDS)

rule loops_fithichip:
    input:
        expand(RESULTS / f"loops/{{sample}}/{{sample}}.interactions_FitHiC_{FITHICHIP_Q_LABEL}.bed", sample=SAMPLE_IDS)

rule loop_qc:
    input:
        expand(RESULTS / "qc/loop_qc/{sample}.json", sample=SAMPLE_IDS)

rule export_oracle:
    input:
        expand(RESULTS / "oracle_cos/{sample}.pt", sample=SAMPLE_IDS)

rule differential_all:
    input:
        expand(RESULTS / "diff/{comparison}/differential_loops.tsv",
               comparison=[c["name"] for c in config.get("differential", {}).get("comparisons", [])])

rule stripes:
    input:
        RESULTS / "stripes/stripe_summary.tsv"

rule figures:
    input:
        RESULTS / "figures/library_summary.tsv"

rule multiqc:
    input:
        RESULTS / "multiqc/multiqc_report.html"
