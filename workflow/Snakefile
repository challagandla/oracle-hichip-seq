# ORACLE HiChIP pipeline — main Snakefile
# Run from repository root:
#   snakemake -s workflow/Snakefile -n --configfile config/config.yaml
#   snakemake -s workflow/Snakefile --cores 32 --configfile config/config.yaml --use-conda
#
# Stages:
#   01_qc_raw          FastQC + fastp adapter/quality trim
#   02_align_pairs     bwa-mem2 -SP5M + pairtools parse/sort/dedup → .pairs.gz
#   03_cool_matrix     cooler load + zoomify + balance (ICE)
#   04_peaks           Extract 1D reads, MACS2 narrow/broad peaks per mark
#   05_loops_fithichip FitHiChIP Peak-to-ALL loop calling
#   06_loop_qc         cis/trans, P(s), insulation, APA, HiCRep replicate QC
#   07_differential    mark-stratified differential loops
#   08_viz             pyGenomeTracks, APA plots, virtual 4C
#   09_export_oracle   Multi-resolution COS graph + node features (PyG / .h5)
#   10_multiqc         Aggregate MultiQC across all stages

import os
import yaml
import pandas as pd
from pathlib import Path

# ---------- Config & sample sheet ----------
configfile: "config/config.yaml"

with open(config["genome_yaml"]) as fh:
    GENOME_CFG = yaml.safe_load(fh)
ASSEMBLY = config["assembly"]
GENOME = GENOME_CFG[ASSEMBLY]

SAMPLES = pd.read_csv(config["samples_tsv"], sep="\t", dtype=str, comment="#").set_index("sample_id", drop=False)
SAMPLE_IDS = SAMPLES["sample_id"].tolist()
MARKS = sorted(SAMPLES["mark"].dropna().unique())

RESULTS = Path(config["results_dir"])
FITHICHIP_Q_LABEL = f"Q{config['fithichip']['fdr_threshold']}"

# convenience accessors used by rule files
def fastq_r1(wc): return SAMPLES.loc[wc.sample, "fastq_r1"]
def fastq_r2(wc): return SAMPLES.loc[wc.sample, "fastq_r2"]
def sample_mark(wc): return SAMPLES.loc[wc.sample, "mark"]
def fithichip_loop_path(sample):
    return RESULTS / f"loops/{sample}/{sample}.interactions_FitHiC_{FITHICHIP_Q_LABEL}.bed"

# ---------- Wildcard constraints ----------
wildcard_constraints:
    sample = r"[A-Za-z0-9_]+",
    res    = r"\d+",
    mark   = r"[A-Za-z0-9]+",
    region = r"[A-Za-z0-9_\-]+",
    comparison = r"[A-Za-z0-9_\-]+"

# ---------- Include all rule files ----------
include: "rules/01_qc_raw.smk"
include: "rules/02_align_pairs.smk"
include: "rules/03_cool_matrix.smk"
include: "rules/04_peaks.smk"
include: "rules/05_loops_fithichip.smk"
include: "rules/06_loop_qc.smk"
include: "rules/07_differential.smk"
include: "rules/08_viz.smk"
include: "rules/09_export_oracle.smk"
include: "rules/10_multiqc.smk"

# ---------- Top-level targets ----------
ORACLE_BIN_SIZES_BP = [int(k) * 1000 for k in config["cooler"]["oracle_bin_sizes_kb"]]

rule all:
    input:
        # Per-sample core artefacts
        expand(RESULTS / "cool/{sample}.mcool", sample=SAMPLE_IDS),
        expand(RESULTS / "peaks/{sample}_peaks.bed", sample=SAMPLE_IDS),
        expand(RESULTS / f"loops/{{sample}}/{{sample}}.interactions_FitHiC_{FITHICHIP_Q_LABEL}.bed", sample=SAMPLE_IDS),
        expand(RESULTS / "qc/loop_qc/{sample}.json", sample=SAMPLE_IDS),
        # ORACLE-ready exports
        expand(RESULTS / "oracle_cos/{sample}.pt", sample=SAMPLE_IDS),
        # Visualisation
        expand(RESULTS / "viz/{sample}_{region}.png",
               sample=SAMPLE_IDS,
               region=[r["name"] for r in config["viz"]["regions"]]),
        # MultiQC aggregate report
        RESULTS / "multiqc/multiqc_report.html"

# ---------- Convenience phony targets ----------
rule qc_raw:
    input:
        expand(RESULTS / "qc/fastqc_raw/{sample}_R1_fastqc.html", sample=SAMPLE_IDS)

rule align_pairs:
    input:
        expand(RESULTS / "pairs/{sample}.dedup.pairs.gz", sample=SAMPLE_IDS)

rule cool_matrix:
    input:
        expand(RESULTS / "cool/{sample}.mcool", sample=SAMPLE_IDS)

rule peaks:
    input:
        expand(RESULTS / "peaks/{sample}_peaks.bed", sample=SAMPLE_IDS)

rule loops_fithichip:
    input:
        expand(RESULTS / f"loops/{{sample}}/{{sample}}.interactions_FitHiC_{FITHICHIP_Q_LABEL}.bed", sample=SAMPLE_IDS)

rule loop_qc:
    input:
        expand(RESULTS / "qc/loop_qc/{sample}.json", sample=SAMPLE_IDS)

rule export_oracle:
    input:
        expand(RESULTS / "oracle_cos/{sample}.pt", sample=SAMPLE_IDS)

rule differential_all:
    input:
        expand(RESULTS / "diff/{comparison}/differential_loops.tsv",
               comparison=[c["name"] for c in config.get("differential", {}).get("comparisons", [])])

rule multiqc:
    input:
        RESULTS / "multiqc/multiqc_report.html"
